    "test:web": "playwright test tests/web",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "perf:50": "k6 run -e ENABLE_50_TPS=true -e ENABLE_100_TPS=false performance/products-add.k6.js",
